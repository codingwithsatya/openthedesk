//@version=5
indicator("OpenTheDesk Manual Planner v3.3.9 — Saty Probability + Quality Engine", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=20)

// =====================================================================
// OPENTHEDESK MANUAL PLANNER v3.3.9 — SATY PROBABILITY + QUALITY ENGINE
//
// Built from v3.3.3 with:
// - Full Saty ladder target engine
// - iVOMY / VOMY full-ladder target fix
// - T1/T2/T3 target validation
// - Fallback targets
// - Runner after T3
// - NEXT target manager
// - SL trails to BE / T1 / Runner SL after T3 / NEXT
// - ATR level names in alert JSON
// - Mobile display profile
// - ORB high / low lines
//
// v3.3.7 added:
// - Risk quality engine
// - Stop Mode: Manual Only / Technical / Capped Technical
// - Minimum T1 reward points filter
// - Maximum stop distance filter
// - Minimum T1 R multiple filter
// - Invalid Risk/Target blocker
// - Cleaner stop status: Before T1 / BE after T1 / After T2 / Runner After T3
// - Runner SL after T3 options: T2 / T3 / Ribbon Pivot / Off
//
// v3.3.8 added:
// - Saty probability classification for T1
// - Risk math variables: risk points, T1 reward points, T1 R
// - Context classification: Aligned / Ribbon OK / Mixed / Counter HTF / Weak
// - Final setup grade: A+ / A / B / B- / C / BLOCK
// - Plan type: Premium / Normal / Aggressive / Runner-Low Prob / Blocked
// - Optional blocks for counter-HTF and low-probability T1
// - Active label now shows Grade / Plan Type
// - Invalid label now shows block reason
//
// v3.3.9 added:
// - Adds atr_level to T1/T2/T3/RUNNER NEXT HIT alert JSON for frontend probability lookup
// =====================================================================

// =====================================================================
// 1. INPUTS
// =====================================================================

visualMode = input.string("Clean Plan Only", "Visual Mode", options=["Full", "Clean Plan Only", "Alerts Only"])
markerMode = input.string("Actionable Only", "Setup Marker Mode", options=["Off", "Actionable Only", "All Raw Signals"])
dashboardMode = input.string("Compact", "Dashboard Mode", options=["Off", "Compact", "Full"])
dashboardPosition = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"])

showTransitionDebug = input.bool(false, "Show VOMY/iVOMY transition debug")
showPlannerEMAsInput = input.bool(false, "Show planner EMAs in Clean mode?")
showPlannerSatyLevelsInput = input.bool(false, "Show internal Saty levels in Clean mode?")

execTf = input.timeframe("3", "Execution timeframe")
onlyExecTf = input.bool(true, "Only detect on execution timeframe")

sessionMode = input.string("Normal", "Session Mode", options=["Normal", "Full Day Backtest", "Late Window"])
normalSession = input.session("0840-1230", "Normal trade window")
fullDaySession = input.session("0840-1600", "Full day backtest window")
lateSession = input.session("1500-1600", "Late window")

resetPlanOnNewDay = input.bool(true, "Reset active plan on new day")

satyTradingType = input.string("Day", "Saty ATR Trading Type", options=["Day", "Multiday", "Swing", "Position", "Long-term"])
satyAtrLength = input.int(14, "Saty ATR Length")
satyTriggerPct = input.float(0.236, "Saty Trigger Percentage", step=0.001)
satyUseCurrentClose = input.bool(false, "Use current close for Saty levels?")

fastLen = input.int(8, "Ribbon Fast EMA")
pullbackLen = input.int(13, "Ribbon Pullback EMA")
pivotLen = input.int(21, "Ribbon Pivot EMA")
slowLen = input.int(34, "Ribbon Slow EMA - Signal State")
longLen = input.int(200, "Long-Term EMA")

useHTFBias = input.bool(true, "Use HTF bias filter")
htf1 = input.timeframe("15", "HTF 1")
htf2 = input.timeframe("30", "HTF 2")
requireBothHTF = input.bool(false, "Require both HTFs aligned?")
allowVomyWithoutHTF = input.bool(true, "Allow VOMY/iVOMY without HTF confirmation")

useGG = input.bool(true, "Detect GG 38→61 Setup")
useFlagIntoRibbon = input.bool(true, "Detect Flag Into Ribbon")
useVomyIvomy = input.bool(true, "Detect VOMY / iVOMY")
useTriggerBacktest = input.bool(true, "Detect Trigger Backtest")
useORBRetest = input.bool(true, "Detect ORB Retest")
useSatyReversal = input.bool(false, "Detect Saty Level Reversal")

// ORB visual + logic.
// CST-aware by default.
// Use 0830-0840 for 10m ORB.
// Use 0830-0845 for 15m ORB.
orbSession = input.session("0830-0840", "ORB range session")
orbTimezone = input.string("America/Chicago", "ORB timezone")

showORBLines = input.bool(true, "Show ORB high / low lines")
showORBMid = input.bool(false, "Show ORB mid line")
showORBLabels = input.bool(true, "Show ORB labels")
orbExtendRight = input.bool(true, "Extend ORB levels right")

orbRetestTolerancePts = input.float(2.0, "ORB retest tolerance points", step=0.25)
oneORBTradePerDirection = input.bool(true, "Only one ORB retest per direction per day")

levelTolerance = input.float(3.0, "Level proximity tolerance", step=0.25)
requireCandleConfirm = input.bool(true, "Require candle confirmation")
minTrendBars = input.int(5, "Minimum trend bars for Flag Into Ribbon", minval=1)

transitionLookbackBars = input.int(12, "VOMY/iVOMY transition lookback bars", minval=3)
retestWindowBars = input.int(24, "VOMY/iVOMY retest window bars", minval=3)
vomyEntryMode = input.string("Retest or Reclaim", "VOMY/iVOMY Entry Mode", options=["Retest Only", "Reclaim Close", "Retest or Reclaim"])

setupCooldownBars = input.int(8, "Minimum bars between new plans", minval=1)
replaceSameDirectionPlans = input.bool(false, "Replace active same-direction plan?")
replaceOppositeDirectionPlans = input.bool(true, "Replace active plan on opposite-direction setup?")
forceOppositeVomyReplace = input.bool(true, "Force opposite VOMY/iVOMY replacement?")
onlyOneActivePlan = input.bool(true, "Keep only one active plan?")
resetCooldownOnInvalidation = input.bool(true, "Allow next setup immediately after invalidation")
resetCooldownOnCompletion = input.bool(true, "Allow next setup immediately after T3 completion")
resetCooldownOnStop = input.bool(true, "Allow next setup immediately after stop")

targetMode = input.string("Next Saty Levels", "Target Mode", options=["Next Saty Levels", "Fixed Saty 38/50/61", "Points", "Risk/Reward"])
fallbackTargetMode = input.string("Points", "If no valid Saty target", options=["Block Plan", "Points", "Risk/Reward"])
minTargetDistancePts = input.float(4.0, "Minimum T1 distance points", step=0.25)

manualStopPts = input.float(8.0, "Manual stop buffer points", step=0.25)
// v3.3.7 — Risk quality engine
stopMode = input.string("Capped Technical", "Stop Mode", options=["Manual Only", "Technical", "Capped Technical"])
minT1RewardPts = input.float(8.0, "Minimum T1 reward points", step=0.25)
maxStopDistancePts = input.float(14.0, "Maximum stop distance points", step=0.25)
minT1R = input.float(0.75, "Minimum T1 R multiple", step=0.05)

// v3.3.7 — Runner behavior after T3
runnerTrailAfterT3 = input.string("T2", "Runner SL after T3", options=["T2", "T3", "Ribbon Pivot", "Off"])
manualT1Pts = input.float(10.0, "Manual T1 points", step=0.25)
manualT2Pts = input.float(20.0, "Manual T2 points", step=0.25)
manualT3Pts = input.float(30.0, "Manual T3 points", step=0.25)

rr1 = input.float(1.0, "T1 R multiple", step=0.25)
rr2 = input.float(2.0, "T2 R multiple", step=0.25)
rr3 = input.float(3.0, "T3 R multiple", step=0.25)

useT3 = input.bool(true, "Draw T3")
t3Behavior = input.string("Hold Runner", "After T3 Hit", options=["Complete Trade", "Hold Runner"])
showRunnerTarget = input.bool(true, "Show NEXT target after T3 runner")
runnerTargetMode = input.string("Saty Only", "Runner target mode", options=["Saty Only", "Points"])

trailMode = input.string("Prior Target", "Trailing SL Mode", options=["Off", "Prior Target"])
trailAlertMinMove = input.float(0.25, "Trail alert minimum move", step=0.25)

displayProfile = input.string("Desktop", "Display profile", options=["Desktop", "Mobile"])

lineBarsInput = input.int(70, "Line projection bars", minval=20)
labelOffsetBarsInput = input.int(45, "Move labels right by bars", minval=2)
labelSpacingTicksInput = input.int(22, "Vertical label spacing in ticks", minval=0)
lineWidthInput = input.int(2, "Line width", minval=1, maxval=5)

lineBars = displayProfile == "Mobile" ? 35 : lineBarsInput
labelOffsetBars = displayProfile == "Mobile" ? 12 : labelOffsetBarsInput
labelSpacingTicks = displayProfile == "Mobile" ? 12 : labelSpacingTicksInput
lineWidth = displayProfile == "Mobile" ? 3 : lineWidthInput

plannerLabelSize = displayProfile == "Mobile" ? size.normal : size.small

deleteOnNewSetup = input.bool(true, "Delete old plan on new setup")
deleteOnComplete = input.bool(false, "Delete lines after completion/stop")
invalidateMode = input.string("Mark", "On invalidation", options=["Mark", "Delete"])
conservativeStops = input.bool(true, "Conservative: stop before target same candle")

hideTargetsOnInvalidation = input.bool(true, "Hide targets when invalidated")
hideTargetsOnStop = input.bool(true, "Hide targets when stopped")
hideTargetsOnComplete = input.bool(false, "Hide targets when completed")

useDynamicAlerts = input.bool(true, "Use dynamic alert() JSON")
tvSecret = input.string("", "TradingView webhook secret")
sendTestAlert = input.bool(false, "Send one test alert on next confirmed bar?")

// v3.3.8 — Saty probability + quality engine
showRiskMathOnDashboard = input.bool(true, "Show risk math on dashboard?")
showSatyProbOnDashboard = input.bool(true, "Show Saty probability on dashboard?")
requireRibbonForAPlus = input.bool(true, "Require Ribbon alignment for A+?")
requireHTFForAPlus = input.bool(true, "Require HTF alignment for A+?")
blockLowProbabilityT1 = input.bool(false, "Block low-probability T1?")
blockCounterHTF = input.bool(false, "Block counter-HTF trades?")


// =====================================================================
// 2. DISPLAY FLAGS
// =====================================================================

showPlan = visualMode != "Alerts Only"
showMarkers = visualMode != "Alerts Only" and markerMode != "Off"
showRawMarkers = showMarkers and markerMode == "All Raw Signals"
showActionableMarkers = showMarkers and markerMode == "Actionable Only"

showPlannerEMAs = visualMode == "Full" or (visualMode == "Clean Plan Only" and showPlannerEMAsInput)
showPlannerSatyLevels = visualMode == "Full" or (visualMode == "Clean Plan Only" and showPlannerSatyLevelsInput)
showDashboard = visualMode != "Alerts Only" and dashboardMode != "Off"

dashPos = dashboardPosition == "Top Right" ? position.top_right :
     dashboardPosition == "Bottom Right" ? position.bottom_right :
     dashboardPosition == "Top Left" ? position.top_left :
     position.bottom_left

// =====================================================================
// 3. BASIC SERIES
// =====================================================================

isExecTf = timeframe.period == execTf
canDetectTf = onlyExecTf ? isExecTf : true

inNormalSession = not na(time(timeframe.period, normalSession))
inFullSession = not na(time(timeframe.period, fullDaySession))
inLateSession = not na(time(timeframe.period, lateSession))

inTradeWindow =
     sessionMode == "Normal" ? inNormalSession :
     sessionMode == "Full Day Backtest" ? inFullSession :
     inNormalSession or inLateSession

rFast = ta.ema(close, fastLen)
rPull = ta.ema(close, pullbackLen)
rPivot = ta.ema(close, pivotLen)
rSlow = ta.ema(close, slowLen)
rLong = ta.ema(close, longLen)

ribbonBull = rFast >= rPivot and rPivot >= rSlow
ribbonBear = rFast <= rPivot and rPivot <= rSlow
ribbonMixed = not ribbonBull and not ribbonBear

ribbonTop = math.max(rFast, math.max(rPull, math.max(rPivot, rSlow)))
ribbonBottom = math.min(rFast, math.min(rPull, math.min(rPivot, rSlow)))

touchesRibbon = low <= ribbonTop and high >= ribbonBottom
touchesPullback = low <= rPull and high >= rPull
touchesPivot = low <= rPivot and high >= rPivot

bullCandle = close > open
bearCandle = close < open

bullConfirm = requireCandleConfirm ? bullCandle and close > close[1] and close > rFast : true
bearConfirm = requireCandleConfirm ? bearCandle and close < close[1] and close < rFast : true

ribbonBullBars = nz(ta.barssince(not ribbonBull), bar_index)
ribbonBearBars = nz(ta.barssince(not ribbonBear), bar_index)

rawPO = ((close - rPivot) / (3.0 * ta.atr(14))) * 100
po = ta.ema(rawPO, 3)
volAvg = ta.sma(volume, 20)
volOk = volume > volAvg

isNewDay = ta.change(time("D")) != 0

// =====================================================================
// 4. SATY ATR LEVELS
// =====================================================================

f_satyTf() =>
    tf = "D"
    if satyTradingType == "Day"
        tf := "D"
    else if satyTradingType == "Multiday"
        tf := "W"
    else if satyTradingType == "Swing"
        tf := "M"
    else if satyTradingType == "Position"
        tf := "3M"
    else if satyTradingType == "Long-term"
        tf := "12M"
    tf

satyPeriodIndex = satyUseCurrentClose ? 0 : 1
satyTicker = ticker.new(syminfo.prefix, syminfo.ticker, session=session.extended)

satyPrevClose = request.security(satyTicker, f_satyTf(), close[satyPeriodIndex], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
satyATR = request.security(satyTicker, f_satyTf(), ta.atr(satyAtrLength)[satyPeriodIndex], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)

satyUpperTrigger = satyPrevClose + satyTriggerPct * satyATR
satyLowerTrigger = satyPrevClose - satyTriggerPct * satyATR

satyUpper382 = satyPrevClose + satyATR * 0.382
satyUpper500 = satyPrevClose + satyATR * 0.500
satyUpper618 = satyPrevClose + satyATR * 0.618
satyUpper786 = satyPrevClose + satyATR * 0.786
satyUpper100 = satyPrevClose + satyATR * 1.000
satyUpper1236 = satyPrevClose + satyATR * 1.236
satyUpper1382 = satyPrevClose + satyATR * 1.382
satyUpper1500 = satyPrevClose + satyATR * 1.500
satyUpper1618 = satyPrevClose + satyATR * 1.618
satyUpper1786 = satyPrevClose + satyATR * 1.786
satyUpper2000 = satyPrevClose + satyATR * 2.000

satyLower382 = satyPrevClose - satyATR * 0.382
satyLower500 = satyPrevClose - satyATR * 0.500
satyLower618 = satyPrevClose - satyATR * 0.618
satyLower786 = satyPrevClose - satyATR * 0.786
satyLower100 = satyPrevClose - satyATR * 1.000
satyLower1236 = satyPrevClose - satyATR * 1.236
satyLower1382 = satyPrevClose - satyATR * 1.382
satyLower1500 = satyPrevClose - satyATR * 1.500
satyLower1618 = satyPrevClose - satyATR * 1.618
satyLower1786 = satyPrevClose - satyATR * 1.786
satyLower2000 = satyPrevClose - satyATR * 2.000

// =====================================================================
// 5. HTF BIAS
// =====================================================================

f_htfRibbonBias(tf) =>
    hFast = request.security(syminfo.tickerid, tf, ta.ema(close, fastLen)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    hPivot = request.security(syminfo.tickerid, tf, ta.ema(close, pivotLen)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    hSlow = request.security(syminfo.tickerid, tf, ta.ema(close, slowLen)[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    hClose = request.security(syminfo.tickerid, tf, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

    hb = hFast >= hPivot and hPivot >= hSlow and hClose >= hPivot
    hr = hFast <= hPivot and hPivot <= hSlow and hClose <= hPivot

    hb ? 1 : hr ? -1 : 0

htfBias1 = f_htfRibbonBias(htf1)
htfBias2 = f_htfRibbonBias(htf2)

htfBull = not useHTFBias ? true : requireBothHTF ? htfBias1 == 1 and htfBias2 == 1 : htfBias1 == 1 or htfBias2 == 1
htfBear = not useHTFBias ? true : requireBothHTF ? htfBias1 == -1 and htfBias2 == -1 : htfBias1 == -1 or htfBias2 == -1

bullBiasOk = htfBull
bearBiasOk = htfBear
vomyBullBiasOk = allowVomyWithoutHTF ? true : htfBull
vomyBearBiasOk = allowVomyWithoutHTF ? true : htfBear

htfText = htfBull and not htfBear ? "BULL" : htfBear and not htfBull ? "BEAR" : "MIXED"

// =====================================================================
// 6. ORB LOGIC + LINES ONLY
// =====================================================================

inORB = not na(time(timeframe.period, orbSession, orbTimezone))
orbStart = inORB and not inORB[1]
orbEnd = not inORB and inORB[1]

var float orbHigh = na
var float orbLow = na
var float orbMid = na
var bool orbBullBroken = false
var bool orbBearBroken = false

var line orbHighLine = na
var line orbLowLine = na
var line orbMidLine = na

var label orbHighLabel = na
var label orbLowLabel = na
var label orbMidLabel = na

var bool orbBullRetestUsed = false
var bool orbBearRetestUsed = false

f_deleteORBObjects() =>
    if not na(orbHighLine)
        line.delete(orbHighLine)
    if not na(orbLowLine)
        line.delete(orbLowLine)
    if not na(orbMidLine)
        line.delete(orbMidLine)
    if not na(orbHighLabel)
        label.delete(orbHighLabel)
    if not na(orbLowLabel)
        label.delete(orbLowLabel)
    if not na(orbMidLabel)
        label.delete(orbMidLabel)

if isNewDay
    orbHigh := na
    orbLow := na
    orbMid := na
    orbBullBroken := false
    orbBearBroken := false
    orbBullRetestUsed := false
    orbBearRetestUsed := false
    f_deleteORBObjects()

if orbStart
    orbHigh := high
    orbLow := low
    orbMid := (orbHigh + orbLow) / 2.0

    orbBullBroken := false
    orbBearBroken := false
    orbBullRetestUsed := false
    orbBearRetestUsed := false

    f_deleteORBObjects()

// Build ORB high/low during the opening range.
// Lines appear after the first confirmed 3m candle,
// then update until the ORB window ends.
if inORB
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow := na(orbLow) ? low : math.min(orbLow, low)
    orbMid := (orbHigh + orbLow) / 2.0

    orbExtend = orbExtendRight ? extend.right : extend.none

    if showORBLines and barstate.isconfirmed
        if na(orbHighLine)
            orbHighLine := line.new(x1=bar_index, y1=orbHigh, x2=bar_index + lineBars, y2=orbHigh, extend=orbExtend, color=color.new(color.green, 0), width=2)
        else
            line.set_y1(orbHighLine, orbHigh)
            line.set_y2(orbHighLine, orbHigh)

        if na(orbLowLine)
            orbLowLine := line.new(x1=bar_index, y1=orbLow, x2=bar_index + lineBars, y2=orbLow, extend=orbExtend, color=color.new(color.red, 0), width=2)
        else
            line.set_y1(orbLowLine, orbLow)
            line.set_y2(orbLowLine, orbLow)

        if showORBMid
            if na(orbMidLine)
                orbMidLine := line.new(x1=bar_index, y1=orbMid, x2=bar_index + lineBars, y2=orbMid, extend=orbExtend, color=color.new(color.yellow, 0), width=1, style=line.style_dashed)
            else
                line.set_y1(orbMidLine, orbMid)
                line.set_y2(orbMidLine, orbMid)

// After ORB ends, freeze the final high/low/mid and place labels.
if orbEnd and showORBLines and not na(orbHigh) and not na(orbLow)
    orbMid := (orbHigh + orbLow) / 2.0

    if not na(orbHighLine)
        line.set_y1(orbHighLine, orbHigh)
        line.set_y2(orbHighLine, orbHigh)

    if not na(orbLowLine)
        line.set_y1(orbLowLine, orbLow)
        line.set_y2(orbLowLine, orbLow)

    if showORBMid and not na(orbMidLine)
        line.set_y1(orbMidLine, orbMid)
        line.set_y2(orbMidLine, orbMid)

    if showORBLabels
        if not na(orbHighLabel)
            label.delete(orbHighLabel)
        if not na(orbLowLabel)
            label.delete(orbLowLabel)
        if not na(orbMidLabel)
            label.delete(orbMidLabel)

        orbHighLabel := label.new(x=bar_index + 2, y=orbHigh, text="ORB High", style=label.style_label_left, color=color.green, textcolor=color.white,size=size.tiny)

        orbLowLabel := label.new(x=bar_index + 2, y=orbLow, text="ORB Low", style=label.style_label_left, color=color.red, textcolor=color.white,size=size.tiny)

        if showORBMid
            orbMidLabel := label.new(x=bar_index + 2, y=orbMid, text="ORB Mid", style=label.style_label_left, color=color.yellow, textcolor=color.black,size=size.tiny)

orbReady = not inORB and not na(orbHigh) and not na(orbLow)

if orbReady and close > orbHigh
    orbBullBroken := true

if orbReady and close < orbLow
    orbBearBroken := true

// =====================================================================
// 7. SETUP CLASSIFICATION
// =====================================================================

// GG = 38.2% GG Open -> 61.8% GG Complete
ggBullOpenCross = ta.crossover(close, satyUpper382)
ggBullOpenRetest = close > satyUpper382 and low <= satyUpper382 + levelTolerance

ggBearOpenCross = ta.crossunder(close, satyLower382)
ggBearOpenRetest = close < satyLower382 and high >= satyLower382 - levelTolerance

ggBull =
     useGG and
     (ggBullOpenCross or ggBullOpenRetest) and
     ribbonBull and
     bullConfirm and
     bullBiasOk

ggBear =
     useGG and
     (ggBearOpenCross or ggBearOpenRetest) and
     ribbonBear and
     bearConfirm and
     bearBiasOk

// Flag Into Ribbon = pullback into 13/21 EMA
flagBull =
     useFlagIntoRibbon and
     ribbonBull and
     ribbonBullBars >= minTrendBars and
     touchesRibbon and
     (touchesPullback or touchesPivot) and
     close > rFast and
     bullConfirm and
     bullBiasOk

flagBear =
     useFlagIntoRibbon and
     ribbonBear and
     ribbonBearBars >= minTrendBars and
     touchesRibbon and
     (touchesPullback or touchesPivot) and
     close < rFast and
     bearConfirm and
     bearBiasOk

// VOMY / iVOMY = transition + retest/reclaim
barsSinceBull = ta.barssince(ribbonBull)
barsSinceBear = ta.barssince(ribbonBear)

bullRibbonRecently = not na(barsSinceBull) and barsSinceBull <= transitionLookbackBars
bearRibbonRecently = not na(barsSinceBear) and barsSinceBear <= transitionLookbackBars

var int bullTransitionBar = na
var int bearTransitionBar = na

iVomyArm =
     useVomyIvomy and
     bearRibbonRecently and
     (
         ta.crossover(close, ribbonTop) or
         close > ribbonTop or
         ta.crossover(rFast, rPivot)
     )

vomyArm =
     useVomyIvomy and
     bullRibbonRecently and
     (
         ta.crossunder(close, ribbonBottom) or
         close < ribbonBottom or
         ta.crossunder(rFast, rPivot)
     )

if iVomyArm
    bullTransitionBar := bar_index
    bearTransitionBar := na

if vomyArm
    bearTransitionBar := bar_index
    bullTransitionBar := na

bullTransitionActive = not na(bullTransitionBar) and bar_index - bullTransitionBar <= retestWindowBars
bearTransitionActive = not na(bearTransitionBar) and bar_index - bearTransitionBar <= retestWindowBars

iVomyRetest =
     bullTransitionActive and
     low <= ribbonTop and
     close > rFast and
     bullConfirm

vomyRetest =
     bearTransitionActive and
     high >= ribbonBottom and
     close < rFast and
     bearConfirm

iVomyReclaim =
     bullTransitionActive and
     close > ribbonTop and
     close > rFast and
     bullConfirm

vomyReclaim =
     bearTransitionActive and
     close < ribbonBottom and
     close < rFast and
     bearConfirm

iVomyEntryOk =
     vomyEntryMode == "Retest Only" ? iVomyRetest :
     vomyEntryMode == "Reclaim Close" ? iVomyReclaim :
     (iVomyRetest or iVomyReclaim)

vomyEntryOk =
     vomyEntryMode == "Retest Only" ? vomyRetest :
     vomyEntryMode == "Reclaim Close" ? vomyReclaim :
     (vomyRetest or vomyReclaim)

iVomyBull =
     useVomyIvomy and
     iVomyEntryOk and
     vomyBullBiasOk

vomyBear =
     useVomyIvomy and
     vomyEntryOk and
     vomyBearBiasOk

if iVomyBull
    bullTransitionBar := na

if vomyBear
    bearTransitionBar := na

// BT = trigger backtest
btBull =
     useTriggerBacktest and
     close > satyUpperTrigger and
     low <= satyUpperTrigger + levelTolerance and
     ribbonBull and
     bullConfirm and
     bullBiasOk

btBear =
     useTriggerBacktest and
     close < satyLowerTrigger and
     high >= satyLowerTrigger - levelTolerance and
     ribbonBear and
     bearConfirm and
     bearBiasOk

// ORB retest.
// ORB range forms during orbSession.
// Setup can trigger later after breakout + retest.
orbBullRetestRaw =
     useORBRetest and
     orbReady and
     orbBullBroken and
     close > orbHigh and
     low <= orbHigh + orbRetestTolerancePts and
     low >= orbHigh - orbRetestTolerancePts and
     bullConfirm and
     bullBiasOk

orbBearRetestRaw =
     useORBRetest and
     orbReady and
     orbBearBroken and
     close < orbLow and
     high >= orbLow - orbRetestTolerancePts and
     high <= orbLow + orbRetestTolerancePts and
     bearConfirm and
     bearBiasOk

orbBullRetest =
     orbBullRetestRaw and
     (not oneORBTradePerDirection or not orbBullRetestUsed)

orbBearRetest =
     orbBearRetestRaw and
     (not oneORBTradePerDirection or not orbBearRetestUsed)

// Optional Saty reversal
nearUpperExtension =
     math.abs(high - satyUpper382) <= levelTolerance or
     math.abs(high - satyUpper500) <= levelTolerance or
     math.abs(high - satyUpper618) <= levelTolerance or
     math.abs(high - satyUpper786) <= levelTolerance or
     math.abs(high - satyUpper100) <= levelTolerance

nearLowerExtension =
     math.abs(low - satyLower382) <= levelTolerance or
     math.abs(low - satyLower500) <= levelTolerance or
     math.abs(low - satyLower618) <= levelTolerance or
     math.abs(low - satyLower786) <= levelTolerance or
     math.abs(low - satyLower100) <= levelTolerance

reversalBull = useSatyReversal and nearLowerExtension and close > rPivot and bullConfirm
reversalBear = useSatyReversal and nearUpperExtension and close < rPivot and bearConfirm

rawBullSetup = iVomyBull or ggBull or flagBull or btBull or orbBullRetest or reversalBull
rawBearSetup = vomyBear or ggBear or flagBear or btBear or orbBearRetest or reversalBear

candidateBullSetup = canDetectTf and inTradeWindow and barstate.isconfirmed and rawBullSetup
candidateBearSetup = canDetectTf and inTradeWindow and barstate.isconfirmed and rawBearSetup

candidateSetupName =
     iVomyBull ? "iVOMY BULL" :
     vomyBear ? "VOMY BEAR" :
     ggBull ? "GG BULL" :
     ggBear ? "GG BEAR" :
     flagBull ? "FLAG INTO RIBBON BULL" :
     flagBear ? "FLAG INTO RIBBON BEAR" :
     btBull ? "BT BULL" :
     btBear ? "BT BEAR" :
     orbBullRetest ? "ORB RETEST BULL" :
     orbBearRetest ? "ORB RETEST BEAR" :
     reversalBull ? "REVERSAL BULL" :
     reversalBear ? "REVERSAL BEAR" :
     "None"

candidateSetupKey =
     str.contains(candidateSetupName, "GG") ? "GG" :
     str.contains(candidateSetupName, "FLAG") ? "FLAG_INTO_RIBBON" :
     str.contains(candidateSetupName, "iVOMY") ? "IVOMY" :
     str.contains(candidateSetupName, "VOMY") ? "VOMY" :
     str.contains(candidateSetupName, "BT") ? "BT" :
     str.contains(candidateSetupName, "ORB") ? "ORB_RETEST" :
     "REVERSAL"

candidateGrade =
     (str.contains(candidateSetupName, "GG") and volOk) or
     (str.contains(candidateSetupName, "FLAG") and volOk) or
     str.contains(candidateSetupName, "VOMY") ? "A+" : "A"

// =====================================================================
// 8. TARGET HELPERS — FULL SATY LADDER
// Bull targets = next level ABOVE entry from full ladder.
// Bear targets = next level BELOW entry from full ladder.
// This fixes iVOMY from lower extensions and VOMY from upper extensions.
// =====================================================================

f_bullNextAfter(level) =>
    na(level) ? na :
     satyLower2000 > level ? satyLower2000 :
     satyLower1786 > level ? satyLower1786 :
     satyLower1618 > level ? satyLower1618 :
     satyLower1500 > level ? satyLower1500 :
     satyLower1382 > level ? satyLower1382 :
     satyLower1236 > level ? satyLower1236 :
     satyLower100 > level ? satyLower100 :
     satyLower786 > level ? satyLower786 :
     satyLower618 > level ? satyLower618 :
     satyLower500 > level ? satyLower500 :
     satyLower382 > level ? satyLower382 :
     satyLowerTrigger > level ? satyLowerTrigger :
     satyPrevClose > level ? satyPrevClose :
     satyUpperTrigger > level ? satyUpperTrigger :
     satyUpper382 > level ? satyUpper382 :
     satyUpper500 > level ? satyUpper500 :
     satyUpper618 > level ? satyUpper618 :
     satyUpper786 > level ? satyUpper786 :
     satyUpper100 > level ? satyUpper100 :
     satyUpper1236 > level ? satyUpper1236 :
     satyUpper1382 > level ? satyUpper1382 :
     satyUpper1500 > level ? satyUpper1500 :
     satyUpper1618 > level ? satyUpper1618 :
     satyUpper1786 > level ? satyUpper1786 :
     satyUpper2000 > level ? satyUpper2000 :
     na

f_bullT1(entry) =>
    minTarget = entry + minTargetDistancePts
    f_bullNextAfter(minTarget)

f_bullT2(entry) =>
    t1 = f_bullT1(entry)
    f_bullNextAfter(t1 + syminfo.mintick)

f_bullT3(entry) =>
    t2 = f_bullT2(entry)
    f_bullNextAfter(t2 + syminfo.mintick)

f_bearNextAfter(level) =>
    na(level) ? na :
     satyUpper2000 < level ? satyUpper2000 :
     satyUpper1786 < level ? satyUpper1786 :
     satyUpper1618 < level ? satyUpper1618 :
     satyUpper1500 < level ? satyUpper1500 :
     satyUpper1382 < level ? satyUpper1382 :
     satyUpper1236 < level ? satyUpper1236 :
     satyUpper100 < level ? satyUpper100 :
     satyUpper786 < level ? satyUpper786 :
     satyUpper618 < level ? satyUpper618 :
     satyUpper500 < level ? satyUpper500 :
     satyUpper382 < level ? satyUpper382 :
     satyUpperTrigger < level ? satyUpperTrigger :
     satyPrevClose < level ? satyPrevClose :
     satyLowerTrigger < level ? satyLowerTrigger :
     satyLower382 < level ? satyLower382 :
     satyLower500 < level ? satyLower500 :
     satyLower618 < level ? satyLower618 :
     satyLower786 < level ? satyLower786 :
     satyLower100 < level ? satyLower100 :
     satyLower1236 < level ? satyLower1236 :
     satyLower1382 < level ? satyLower1382 :
     satyLower1500 < level ? satyLower1500 :
     satyLower1618 < level ? satyLower1618 :
     satyLower1786 < level ? satyLower1786 :
     satyLower2000 < level ? satyLower2000 :
     na

f_bearT1(entry) =>
    maxTarget = entry - minTargetDistancePts
    f_bearNextAfter(maxTarget)

f_bearT2(entry) =>
    t1 = f_bearT1(entry)
    f_bearNextAfter(t1 - syminfo.mintick)

f_bearT3(entry) =>
    t2 = f_bearT2(entry)
    f_bearNextAfter(t2 - syminfo.mintick)

f_applyFallbackTargets(dir, entry, riskDist) =>
    float ft1 = na
    float ft2 = na
    float ft3 = na

    if fallbackTargetMode == "Points"
        if dir == 1
            ft1 := entry + manualT1Pts
            ft2 := entry + manualT2Pts
            ft3 := entry + manualT3Pts
        if dir == -1
            ft1 := entry - manualT1Pts
            ft2 := entry - manualT2Pts
            ft3 := entry - manualT3Pts

    if fallbackTargetMode == "Risk/Reward"
        if dir == 1
            ft1 := entry + riskDist * rr1
            ft2 := entry + riskDist * rr2
            ft3 := entry + riskDist * rr3
        if dir == -1
            ft1 := entry - riskDist * rr1
            ft2 := entry - riskDist * rr2
            ft3 := entry - riskDist * rr3

    [ft1, ft2, ft3]

f_targetsValid(dir, entry, t1, t2, t3) =>
    hasT1 = not na(t1)
    hasT2 = not na(t2)
    hasT3 = not na(t3)

    dir == 1 ? hasT1 and hasT2 and hasT3 and t1 > entry and t2 > t1 and t3 > t2 :
     dir == -1 ? hasT1 and hasT2 and hasT3 and t1 < entry and t2 < t1 and t3 < t2 :
     false

f_planRiskValid(dir, entry, stop, t1) =>
    stopRisk = dir == 1 ? entry - stop : stop - entry
    t1Reward = dir == 1 ? t1 - entry : entry - t1
    t1R = stopRisk > 0 ? t1Reward / stopRisk : 0.0

    stopRisk > 0 and
     t1Reward >= minT1RewardPts and
     stopRisk <= maxStopDistancePts and
     t1R >= minT1R

f_riskPts(dir, entry, stop) =>
    dir == 1 ? entry - stop :
     dir == -1 ? stop - entry :
     na

f_rewardPts(dir, entry, target) =>
    dir == 1 ? target - entry :
     dir == -1 ? entry - target :
     na

f_rMultiple(riskPts, rewardPts) =>
    not na(riskPts) and riskPts > 0 and not na(rewardPts) ? rewardPts / riskPts : na

f_satyProbClass(price) =>
    string cls = "CUSTOM"

    nearLowerTrig = math.abs(price - satyLowerTrigger) <= syminfo.mintick
    nearLower382 = math.abs(price - satyLower382) <= syminfo.mintick
    nearLower500 = math.abs(price - satyLower500) <= syminfo.mintick
    nearLower618 = math.abs(price - satyLower618) <= syminfo.mintick
    nearLower786 = math.abs(price - satyLower786) <= syminfo.mintick
    nearLower100 = math.abs(price - satyLower100) <= syminfo.mintick
    nearLower1236 = math.abs(price - satyLower1236) <= syminfo.mintick

    nearUpperTrig = math.abs(price - satyUpperTrigger) <= syminfo.mintick
    nearUpper382 = math.abs(price - satyUpper382) <= syminfo.mintick
    nearUpper500 = math.abs(price - satyUpper500) <= syminfo.mintick
    nearUpper618 = math.abs(price - satyUpper618) <= syminfo.mintick
    nearUpper786 = math.abs(price - satyUpper786) <= syminfo.mintick
    nearUpper100 = math.abs(price - satyUpper100) <= syminfo.mintick
    nearUpper1236 = math.abs(price - satyUpper1236) <= syminfo.mintick

    nearLowerExt =
         math.abs(price - satyLower1382) <= syminfo.mintick or
         math.abs(price - satyLower1500) <= syminfo.mintick or
         math.abs(price - satyLower1618) <= syminfo.mintick or
         math.abs(price - satyLower1786) <= syminfo.mintick or
         math.abs(price - satyLower2000) <= syminfo.mintick

    nearUpperExt =
         math.abs(price - satyUpper1382) <= syminfo.mintick or
         math.abs(price - satyUpper1500) <= syminfo.mintick or
         math.abs(price - satyUpper1618) <= syminfo.mintick or
         math.abs(price - satyUpper1786) <= syminfo.mintick or
         math.abs(price - satyUpper2000) <= syminfo.mintick

    if nearLowerTrig or nearUpperTrig or nearLower382 or nearUpper382 or nearLower500 or nearUpper500 or nearLower618 or nearUpper618
        cls := "HIGH"
    else if nearLower786 or nearUpper786
        cls := "GOOD"
    else if nearLower100 or nearUpper100
        cls := "MOMENTUM"
    else if nearLower1236 or nearUpper1236
        cls := "RUNNER"
    else if nearLowerExt or nearUpperExt
        cls := "STRONG MOM"
    else
        cls := "CUSTOM"

    cls

f_contextClass(dir) =>
    ribbonAligned = dir == 1 ? ribbonBull : dir == -1 ? ribbonBear : false
    htfAligned = dir == 1 ? htfBull : dir == -1 ? htfBear : false
    htfCounter = dir == 1 ? htfBear : dir == -1 ? htfBull : false

    ribbonAligned and htfAligned ? "ALIGNED" :
     ribbonAligned and not htfCounter ? "RIBBON OK" :
     ribbonMixed ? "MIXED" :
     htfCounter ? "COUNTER HTF" :
     "WEAK"

f_qualityGrade(riskOk, probClass, contextClass) =>
    highProb = probClass == "HIGH" or probClass == "GOOD"
    weakProb = probClass == "RUNNER" or probClass == "STRONG MOM"
    aligned = contextClass == "ALIGNED"
    ribbonOk = contextClass == "RIBBON OK"

    not riskOk ? "BLOCK" :
     aligned and highProb ? "A+" :
     ribbonOk and highProb ? "A" :
     contextClass == "MIXED" ? "B" :
     contextClass == "COUNTER HTF" ? "B-" :
     weakProb ? "C" :
     "B"

f_runnerNextTarget(dir, fromLevel) =>
    dir == 1 ? f_bullNextAfter(fromLevel + syminfo.mintick) :
     dir == -1 ? f_bearNextAfter(fromLevel - syminfo.mintick) :
     na

f_atrLevelName(price, dir) =>
    string out = "custom"

    if dir == 1
        out := math.abs(price - satyLower2000) <= syminfo.mintick ? "lower_2atr" :
             math.abs(price - satyLower1786) <= syminfo.mintick ? "lower_1786" :
             math.abs(price - satyLower1618) <= syminfo.mintick ? "lower_1618" :
             math.abs(price - satyLower1500) <= syminfo.mintick ? "lower_150" :
             math.abs(price - satyLower1382) <= syminfo.mintick ? "lower_1382" :
             math.abs(price - satyLower1236) <= syminfo.mintick ? "lower_1236" :
             math.abs(price - satyLower100) <= syminfo.mintick ? "lower_1atr" :
             math.abs(price - satyLower786) <= syminfo.mintick ? "lower_786" :
             math.abs(price - satyLower618) <= syminfo.mintick ? "lower_618_gg_comp" :
             math.abs(price - satyLower500) <= syminfo.mintick ? "lower_50_mid" :
             math.abs(price - satyLower382) <= syminfo.mintick ? "lower_382_gg_open" :
             math.abs(price - satyLowerTrigger) <= syminfo.mintick ? "put_trigger" :
             math.abs(price - satyPrevClose) <= syminfo.mintick ? "pdc" :
             math.abs(price - satyUpperTrigger) <= syminfo.mintick ? "call_trigger" :
             math.abs(price - satyUpper382) <= syminfo.mintick ? "upper_382_gg_open" :
             math.abs(price - satyUpper500) <= syminfo.mintick ? "upper_50_mid" :
             math.abs(price - satyUpper618) <= syminfo.mintick ? "upper_618_gg_comp" :
             math.abs(price - satyUpper786) <= syminfo.mintick ? "upper_786" :
             math.abs(price - satyUpper100) <= syminfo.mintick ? "upper_1atr" :
             math.abs(price - satyUpper1236) <= syminfo.mintick ? "upper_1236" :
             math.abs(price - satyUpper1382) <= syminfo.mintick ? "upper_1382" :
             math.abs(price - satyUpper1500) <= syminfo.mintick ? "upper_150" :
             math.abs(price - satyUpper1618) <= syminfo.mintick ? "upper_1618" :
             math.abs(price - satyUpper1786) <= syminfo.mintick ? "upper_1786" :
             math.abs(price - satyUpper2000) <= syminfo.mintick ? "upper_2atr" :
             "custom_bull"

    if dir == -1
        out := math.abs(price - satyUpper2000) <= syminfo.mintick ? "upper_2atr" :
             math.abs(price - satyUpper1786) <= syminfo.mintick ? "upper_1786" :
             math.abs(price - satyUpper1618) <= syminfo.mintick ? "upper_1618" :
             math.abs(price - satyUpper1500) <= syminfo.mintick ? "upper_150" :
             math.abs(price - satyUpper1382) <= syminfo.mintick ? "upper_1382" :
             math.abs(price - satyUpper1236) <= syminfo.mintick ? "upper_1236" :
             math.abs(price - satyUpper100) <= syminfo.mintick ? "upper_1atr" :
             math.abs(price - satyUpper786) <= syminfo.mintick ? "upper_786" :
             math.abs(price - satyUpper618) <= syminfo.mintick ? "upper_618_gg_comp" :
             math.abs(price - satyUpper500) <= syminfo.mintick ? "upper_50_mid" :
             math.abs(price - satyUpper382) <= syminfo.mintick ? "upper_382_gg_open" :
             math.abs(price - satyUpperTrigger) <= syminfo.mintick ? "call_trigger" :
             math.abs(price - satyPrevClose) <= syminfo.mintick ? "pdc" :
             math.abs(price - satyLowerTrigger) <= syminfo.mintick ? "put_trigger" :
             math.abs(price - satyLower382) <= syminfo.mintick ? "lower_382_gg_open" :
             math.abs(price - satyLower500) <= syminfo.mintick ? "lower_50_mid" :
             math.abs(price - satyLower618) <= syminfo.mintick ? "lower_618_gg_comp" :
             math.abs(price - satyLower786) <= syminfo.mintick ? "lower_786" :
             math.abs(price - satyLower100) <= syminfo.mintick ? "lower_1atr" :
             math.abs(price - satyLower1236) <= syminfo.mintick ? "lower_1236" :
             math.abs(price - satyLower1382) <= syminfo.mintick ? "lower_1382" :
             math.abs(price - satyLower1500) <= syminfo.mintick ? "lower_150" :
             math.abs(price - satyLower1618) <= syminfo.mintick ? "lower_1618" :
             math.abs(price - satyLower1786) <= syminfo.mintick ? "lower_1786" :
             math.abs(price - satyLower2000) <= syminfo.mintick ? "lower_2atr" :
             "custom_bear"

    out

// =====================================================================
// 9. TRADE STATE
// =====================================================================

var bool activeTrade = false
var bool t1WasHit = false
var bool t2WasHit = false
var bool t3WasHit = false

var int tradeDir = 0
var int lastSetupBar = na

var float entryPrice = na
var float t1Price = na
var float t2Price = na
var float t3Price = na
var float slPrice = na
var float trailSL = na
var bool runnerActive = false
var int runnerTargetNumber = 0
var float runnerTargetPrice = na
var float lastRunnerHitPrice = na

var line runnerTargetLine = na
var label runnerTargetLabel = na
var float lastTrailAlertSL = na

var string tradeStatus = "Waiting"
var string currentSetup = "None"
var string currentSetupKey = "None"
var string currentGrade = "A"
var string trailState = "SL"

var line entryLine = na
var line t1Line = na
var line t2Line = na
var line t3Line = na
var line slLine = na

var label entryLabel = na
var label t1Label = na
var label t2Label = na
var label t3Label = na
var label slLabel = na
var label statusLabel = na
var bool testAlertSent = false

var float planRiskPts = na
var float planT1RewardPts = na
var float planT1R = na
var string planRiskStatus = "WAIT"
var string planProbClass = "WAIT"
var string planContextClass = "WAIT"
var string planType = "WAIT"

newBullEvent = false
newBearEvent = false
entryEvent = false
t1Event = false
t2Event = false
t3Event = false
stopEvent = false
invalidEvent = false
trailEvent = false
runnerEvent = false
runnerNextHitEvent = false
runnerMaxEvent = false
reversalExitEvent = false

newBullEvent := false
newBearEvent := false
entryEvent := false
t1Event := false
t2Event := false
t3Event := false
stopEvent := false
invalidEvent := false
trailEvent := false
runnerEvent := false
runnerNextHitEvent := false
runnerMaxEvent := false
reversalExitEvent := false
testAlertSent := false

f_deletePlan() =>
    if not na(entryLine)
        line.delete(entryLine)
    if not na(t1Line)
        line.delete(t1Line)
    if not na(t2Line)
        line.delete(t2Line)
    if not na(t3Line)
        line.delete(t3Line)
    if not na(slLine)
        line.delete(slLine)

    if not na(entryLabel)
        label.delete(entryLabel)
    if not na(t1Label)
        label.delete(t1Label)
    if not na(t2Label)
        label.delete(t2Label)
    if not na(t3Label)
        label.delete(t3Label)
    if not na(slLabel)
        label.delete(slLabel)
    if not na(statusLabel)
        label.delete(statusLabel)
    if not na(runnerTargetLine)
        line.delete(runnerTargetLine)
    if not na(runnerTargetLabel)
        label.delete(runnerTargetLabel)

f_clearPlanLinesKeepStatus() =>
    if not na(entryLine)
        line.delete(entryLine)
    if not na(t1Line)
        line.delete(t1Line)
    if not na(t2Line)
        line.delete(t2Line)
    if not na(t3Line)
        line.delete(t3Line)
    if not na(slLine)
        line.delete(slLine)

    if not na(entryLabel)
        label.delete(entryLabel)
    if not na(t1Label)
        label.delete(t1Label)
    if not na(t2Label)
        label.delete(t2Label)
    if not na(t3Label)
        label.delete(t3Label)
    if not na(slLabel)
        label.delete(slLabel)
    if not na(runnerTargetLine)
        line.delete(runnerTargetLine)
    if not na(runnerTargetLabel)
        label.delete(runnerTargetLabel)

f_refreshPlanLabels() =>
    if showPlan
        lx = bar_index + labelOffsetBars
        tickSpace = syminfo.mintick * labelSpacingTicks

        if not na(entryLine)
            line.set_y1(entryLine, entryPrice)
            line.set_y2(entryLine, entryPrice)
        if not na(t1Line)
            line.set_y1(t1Line, t1Price)
            line.set_y2(t1Line, t1Price)
        if not na(t2Line)
            line.set_y1(t2Line, t2Price)
            line.set_y2(t2Line, t2Price)
        if not na(t3Line)
            line.set_y1(t3Line, t3Price)
            line.set_y2(t3Line, t3Price)
        if not na(slLine)
            line.set_y1(slLine, trailSL)
            line.set_y2(slLine, trailSL)

        if not na(entryLabel)
            label.set_x(entryLabel, lx)
            label.set_y(entryLabel, entryPrice)
            label.set_text(entryLabel, "ENTRY\n" + str.tostring(entryPrice, format.mintick))
        if not na(t1Label)
            label.set_x(t1Label, lx)
            label.set_y(t1Label, t1Price + tickSpace)
            label.set_text(t1Label, (t1WasHit ? "T1 HIT\n" : "T1\n") + str.tostring(t1Price, format.mintick))
        if not na(t2Label)
            label.set_x(t2Label, lx)
            label.set_y(t2Label, t2Price + tickSpace * 2)
            label.set_text(t2Label, (t2WasHit ? "T2 HIT\n" : "T2\n") + str.tostring(t2Price, format.mintick))
        if not na(t3Label)
            label.set_x(t3Label, lx)
            label.set_y(t3Label, t3Price + tickSpace * 3)
            label.set_text(t3Label, (t3WasHit ? "T3 HIT\n" : "T3\n") + str.tostring(t3Price, format.mintick))
        if not na(slLabel)
            label.set_x(slLabel, lx)
            label.set_y(slLabel, trailSL - tickSpace)
            label.set_text(slLabel, trailState + "\n" + str.tostring(trailSL, format.mintick))
        if not na(statusLabel)
            label.set_x(statusLabel, lx)

// =====================================================================
// 9B. DAILY PLAN RESET
// =====================================================================

if resetPlanOnNewDay and isNewDay
    f_deletePlan()

    activeTrade := false
    t1WasHit := false
    t2WasHit := false
    t3WasHit := false

    tradeDir := 0
    lastSetupBar := na

    entryPrice := na
    t1Price := na
    t2Price := na
    t3Price := na
    slPrice := na
    trailSL := na
    runnerActive := false
    runnerTargetNumber := 0
    runnerTargetPrice := na
    lastRunnerHitPrice := na
    lastTrailAlertSL := na

    tradeStatus := "Waiting"
    currentSetup := "None"
    currentSetupKey := "None"
    currentGrade := "A"
    trailState := "SL"

    planRiskPts := na
    planT1RewardPts := na
    planT1R := na
    planRiskStatus := "WAIT"
    planProbClass := "WAIT"
    planContextClass := "WAIT"
    planType := "WAIT"

// =====================================================================
// 10. NEW SETUP GATING
// =====================================================================

cooldownOk = na(lastSetupBar) or bar_index - lastSetupBar >= setupCooldownBars

candidateDir =
     candidateBullSetup ? 1 :
     candidateBearSetup ? -1 :
     0

oppositeDirectionCandidate =
     activeTrade and candidateDir != 0 and candidateDir != tradeDir

sameDirectionCandidate =
     activeTrade and candidateDir != 0 and candidateDir == tradeDir

oppositeVomyCandidate =
     oppositeDirectionCandidate and
     (candidateSetupKey == "VOMY" or candidateSetupKey == "IVOMY")

isCompletedOrInactive =
     not activeTrade or
     tradeStatus == "Stopped" or
     tradeStatus == "Invalidated" or
     str.contains(tradeStatus, "Completed")

canReplacePlan =
     not onlyOneActivePlan ? true :
     isCompletedOrInactive ? true :
     sameDirectionCandidate and replaceSameDirectionPlans ? true :
     oppositeVomyCandidate and forceOppositeVomyReplace ? true :
     oppositeDirectionCandidate and replaceOppositeDirectionPlans ? true :
     false

newSetup = (cooldownOk or oppositeVomyCandidate) and canReplacePlan and (candidateBullSetup or candidateBearSetup)
newBullSetup = newSetup and candidateBullSetup
newBearSetup = newSetup and candidateBearSetup

// =====================================================================
// 11. CREATE NEW PLAN
// =====================================================================

if newSetup
    if activeTrade and oppositeDirectionCandidate
        reversalExitEvent := true

    if deleteOnNewSetup
        f_deletePlan()

    lastSetupBar := bar_index

    tradeDir := newBullSetup ? 1 : -1

    if candidateSetupKey == "ORB_RETEST"
        if tradeDir == 1
            orbBullRetestUsed := true
        if tradeDir == -1
            orbBearRetestUsed := true

    activeTrade := true
    t1WasHit := false
    t2WasHit := false
    t3WasHit := false
    runnerActive := false
    runnerTargetNumber := 0
    runnerTargetPrice := na
    lastRunnerHitPrice := na

    tradeStatus := "Active"
    currentSetup := candidateSetupName
    currentSetupKey := candidateSetupKey
    currentGrade := candidateGrade

    entryPrice := close
    riskDist = manualStopPts

    if tradeDir == 1
        if currentSetupKey == "GG"
            t1Price := satyUpper618
            t2Price := satyUpper786
            t3Price := satyUpper100
        else if targetMode == "Next Saty Levels"
            t1Price := f_bullT1(entryPrice)
            t2Price := f_bullT2(entryPrice)
            t3Price := f_bullT3(entryPrice)
        else if targetMode == "Fixed Saty 38/50/61"
            t1Price := satyUpper382
            t2Price := satyUpper500
            t3Price := satyUpper618
        else if targetMode == "Points"
            t1Price := entryPrice + manualT1Pts
            t2Price := entryPrice + manualT2Pts
            t3Price := entryPrice + manualT3Pts
        else
            t1Price := entryPrice + riskDist * rr1
            t2Price := entryPrice + riskDist * rr2
            t3Price := entryPrice + riskDist * rr3

        technicalStop = math.min(low, ribbonBottom) - syminfo.mintick
        manualStop = entryPrice - manualStopPts
        maxAllowedStop = entryPrice - maxStopDistancePts

        slPrice := stopMode == "Manual Only" ? manualStop : stopMode == "Technical" ? technicalStop : math.max(technicalStop, maxAllowedStop)

        trailSL := slPrice

    if tradeDir == -1
        if currentSetupKey == "GG"
            t1Price := satyLower618
            t2Price := satyLower786
            t3Price := satyLower100
        else if targetMode == "Next Saty Levels"
            t1Price := f_bearT1(entryPrice)
            t2Price := f_bearT2(entryPrice)
            t3Price := f_bearT3(entryPrice)
        else if targetMode == "Fixed Saty 38/50/61"
            t1Price := satyLower382
            t2Price := satyLower500
            t3Price := satyLower618
        else if targetMode == "Points"
            t1Price := entryPrice - manualT1Pts
            t2Price := entryPrice - manualT2Pts
            t3Price := entryPrice - manualT3Pts
        else
            t1Price := entryPrice - riskDist * rr1
            t2Price := entryPrice - riskDist * rr2
            t3Price := entryPrice - riskDist * rr3

        technicalStop = math.max(high, ribbonTop) + syminfo.mintick
        manualStop = entryPrice + manualStopPts
        maxAllowedStop = entryPrice + maxStopDistancePts

        slPrice := stopMode == "Manual Only" ? manualStop : stopMode == "Technical" ? technicalStop : math.min(technicalStop, maxAllowedStop)

        trailSL := slPrice

    targetsValid = f_targetsValid(tradeDir, entryPrice, t1Price, t2Price, t3Price)

    // If Saty ladder ran out, use fallback targets if allowed.
    if not targetsValid and fallbackTargetMode != "Block Plan"
        [fbT1, fbT2, fbT3] = f_applyFallbackTargets(tradeDir, entryPrice, riskDist)
        t1Price := fbT1
        t2Price := fbT2
        t3Price := fbT3
        targetsValid := f_targetsValid(tradeDir, entryPrice, t1Price, t2Price, t3Price)

    riskValid = f_planRiskValid(tradeDir, entryPrice, slPrice, t1Price)
    planValid = targetsValid and riskValid

    planRiskPts := f_riskPts(tradeDir, entryPrice, slPrice)
    planT1RewardPts := f_rewardPts(tradeDir, entryPrice, t1Price)
    planT1R := f_rMultiple(planRiskPts, planT1RewardPts)

    planRiskStatus := riskValid ? "PASS" : "FAIL"
    planProbClass := targetsValid ? f_satyProbClass(t1Price) : "NO TARGET"
    planContextClass := f_contextClass(tradeDir)

    counterHtfBlocked = blockCounterHTF and planContextClass == "COUNTER HTF"
    lowProbBlocked = blockLowProbabilityT1 and (planProbClass == "RUNNER" or planProbClass == "STRONG MOM")

    if counterHtfBlocked or lowProbBlocked
        planValid := false
        planRiskStatus := counterHtfBlocked ? "BLOCK COUNTER HTF" : "BLOCK LOW PROB"

    currentGrade := f_qualityGrade(planValid, planProbClass, planContextClass)

    planType := currentGrade == "A+" ? "PREMIUM" :
         currentGrade == "A" ? "NORMAL" :
         currentGrade == "B" or currentGrade == "B-" ? "AGGRESSIVE" :
         currentGrade == "C" ? "RUNNER/LOW PROB" :
         "BLOCKED"

    // If target path or risk/reward is invalid, block the plan.
    if not planValid
        activeTrade := false
        tradeStatus := "Invalid Risk/Target"
        currentSetup := candidateSetupName + " EXTENDED"
        currentSetupKey := candidateSetupKey
        currentGrade := "BLOCK"
        planType := "BLOCKED"

        entryPrice := na
        t1Price := na
        t2Price := na
        t3Price := na
        slPrice := na
        trailSL := na
        trailState := "SL"

        newBullEvent := false
        newBearEvent := false
        entryEvent := false

        if showPlan
            label.new(bar_index, close, candidateSetupName + "\nINVALID RISK/TARGET\n" + planRiskStatus, style=label.style_label_left, color=color.gray, textcolor=color.white, size=plannerLabelSize)

    if activeTrade
        lastTrailAlertSL := trailSL
        trailState := "SL"

    if activeTrade and showPlan
        planColor = tradeDir == 1 ? color.lime : color.red
        targetColor = tradeDir == 1 ? color.green : color.maroon
        stopColor = color.orange

        labelX = bar_index + labelOffsetBars
        tickSpace = syminfo.mintick * labelSpacingTicks

        entryLine := line.new(bar_index, entryPrice, bar_index + lineBars, entryPrice, extend=extend.right, color=planColor, width=lineWidth)

        t1Line := line.new(bar_index, t1Price, bar_index + lineBars, t1Price, extend=extend.right, color=targetColor, width=lineWidth)

        t2Line := line.new(bar_index, t2Price, bar_index + lineBars, t2Price, extend=extend.right, color=targetColor, width=lineWidth)

        slLine := line.new(bar_index, trailSL, bar_index + lineBars, trailSL, extend=extend.right, color=stopColor, width=lineWidth + 1, style=line.style_dashed)

        if useT3
            t3Line := line.new(bar_index, t3Price, bar_index + lineBars, t3Price, extend=extend.right, color=color.blue, width=lineWidth)

        entryLabel := label.new(labelX, entryPrice, "ENTRY\n" + str.tostring(entryPrice, format.mintick), style=label.style_label_left, color=planColor, textcolor=color.white, size=plannerLabelSize)

        t1Label := label.new(labelX, t1Price + tickSpace, "T1\n" + str.tostring(t1Price, format.mintick), style=label.style_label_left, color=targetColor,textcolor=color.white, size=plannerLabelSize)

        t2Label := label.new(labelX, t2Price + tickSpace * 2, "T2\n" + str.tostring(t2Price, format.mintick), style=label.style_label_left, color=targetColor, textcolor=color.white, size=plannerLabelSize)

        slLabel := label.new(labelX, trailSL - tickSpace, trailState + "\n" + str.tostring(trailSL, format.mintick), style=label.style_label_left, color=stopColor, textcolor=color.black, size=plannerLabelSize)

        if useT3
            t3Label := label.new(labelX, t3Price + tickSpace * 3, "T3\n" + str.tostring(t3Price, format.mintick), style=label.style_label_left, color=color.blue, textcolor=color.white, size=plannerLabelSize)

        statusLabel := label.new(labelX, entryPrice + tickSpace * 4, currentSetup + "\nACTIVE\n" + currentGrade + " / " + planType, style=label.style_label_left, color=planColor, textcolor=color.white, size=plannerLabelSize)

    if activeTrade
        newBullEvent := tradeDir == 1
        newBearEvent := tradeDir == -1
        entryEvent := true
// =====================================================================
// 12. TRADE MANAGEMENT
// =====================================================================

if activeTrade and not newSetup
    invalidBull = tradeDir == 1 and ribbonBear
    invalidBear = tradeDir == -1 and ribbonBull
    biasInvalid = invalidBull or invalidBear

    bullStopHit = tradeDir == 1 and low <= trailSL
    bearStopHit = tradeDir == -1 and high >= trailSL
    stopHit = bullStopHit or bearStopHit

    bullT1Hit = tradeDir == 1 and high >= t1Price
    bearT1Hit = tradeDir == -1 and low <= t1Price
    t1Hit = bullT1Hit or bearT1Hit

    bullT2Hit = tradeDir == 1 and high >= t2Price
    bearT2Hit = tradeDir == -1 and low <= t2Price
    t2Hit = bullT2Hit or bearT2Hit

    bullT3Hit = tradeDir == 1 and useT3 and high >= t3Price
    bearT3Hit = tradeDir == -1 and useT3 and low <= t3Price
    t3Hit = bullT3Hit or bearT3Hit

    if biasInvalid
        tradeStatus := "Invalidated"
        invalidEvent := true
        activeTrade := false

        if resetCooldownOnInvalidation
            lastSetupBar := na

        if invalidateMode == "Delete"
            f_deletePlan()
        else
            if hideTargetsOnInvalidation
                f_clearPlanLinesKeepStatus()

            if not na(statusLabel)
                label.set_text(statusLabel, currentSetup + "\nINVALIDATED")
                label.set_color(statusLabel, color.gray)
                label.set_textcolor(statusLabel, color.white)

    else if stopHit and conservativeStops
        tradeStatus := t3WasHit ? "Runner Stopped After T3" : t2WasHit ? "Stopped After T2" : t1WasHit ? "Stopped BE/After T1" : "Stopped Before T1"
        stopEvent := true
        activeTrade := false

        if resetCooldownOnStop
            lastSetupBar := na

        if hideTargetsOnStop
            f_clearPlanLinesKeepStatus()

        if not na(statusLabel)
            label.set_text(statusLabel, currentSetup + "\n" + tradeStatus)
            label.set_color(statusLabel, color.orange)
            label.set_textcolor(statusLabel, color.black)

        if deleteOnComplete
            f_deletePlan()

    else
        // -------------------------------
        // T1 HIT
        // -------------------------------
        if t1Hit and not t1WasHit
            t1WasHit := true
            t1Event := true
            tradeStatus := "T1 Hit"

            if trailMode == "Prior Target"
                if tradeDir == 1
                    trailSL := math.max(trailSL, entryPrice)
                    trailState := "SL BE"
                if tradeDir == -1
                    trailSL := math.min(trailSL, entryPrice)
                    trailState := "SL BE"

                trailEvent := true

                if showPlan and not na(trailSL)
                    if not na(slLine)
                        line.delete(slLine)
                    if not na(slLabel)
                        label.delete(slLabel)

                    lxTrail = bar_index + labelOffsetBars
                    tickSpaceTrail = syminfo.mintick * labelSpacingTicks

                    slLine := line.new(bar_index, trailSL, bar_index + lineBars, trailSL, extend=extend.right, color=color.orange, width=lineWidth + 2, style=line.style_dashed)

                    slLabel := label.new(lxTrail, trailSL - tickSpaceTrail, trailState + "\n" + str.tostring(trailSL, format.mintick), style=label.style_label_left, color=color.orange, textcolor=color.black, size=plannerLabelSize)

            if not na(statusLabel)
                label.set_text(statusLabel, currentSetup + "\nT1 HIT")
                label.set_color(statusLabel, color.blue)
                label.set_textcolor(statusLabel, color.white)

        // -------------------------------
        // T2 HIT
        // -------------------------------
        if t2Hit and not t2WasHit
            t2WasHit := true
            t2Event := true
            tradeStatus := "T2 Hit"

            if trailMode == "Prior Target"
                if tradeDir == 1
                    trailSL := math.max(trailSL, t1Price)
                    trailState := "SL T1"
                if tradeDir == -1
                    trailSL := math.min(trailSL, t1Price)
                    trailState := "SL T1"

                trailEvent := true
                if showPlan and not na(trailSL)
                    if not na(slLine)
                        line.delete(slLine)
                    if not na(slLabel)
                        label.delete(slLabel)

                    lxTrail = bar_index + labelOffsetBars
                    tickSpaceTrail = syminfo.mintick * labelSpacingTicks

                    slLine := line.new(bar_index, trailSL, bar_index + lineBars, trailSL, extend=extend.right, color=color.orange, width=lineWidth + 2, style=line.style_dashed)

                    slLabel := label.new(lxTrail, trailSL - tickSpaceTrail, trailState + "\n" + str.tostring(trailSL, format.mintick), style=label.style_label_left, color=color.orange,textcolor=color.black, size=plannerLabelSize)
                

            if not na(statusLabel)
                label.set_text(statusLabel, currentSetup + "\nT2 HIT")
                label.set_color(statusLabel, color.blue)
                label.set_textcolor(statusLabel, color.white)

        // -------------------------------
        // T3 HIT
        // -------------------------------
        if t3Hit and not t3WasHit
            t3WasHit := true
            t3Event := true

            if trailMode == "Prior Target"
                if runnerTrailAfterT3 == "T2"
                    if tradeDir == 1
                        trailSL := math.max(trailSL, t2Price)
                    if tradeDir == -1
                        trailSL := math.min(trailSL, t2Price)
                    trailState := "RUNNER SL T2"

                else if runnerTrailAfterT3 == "T3"
                    if tradeDir == 1
                        trailSL := math.max(trailSL, t3Price)
                    if tradeDir == -1
                        trailSL := math.min(trailSL, t3Price)
                    trailState := "RUNNER SL T3"

                else if runnerTrailAfterT3 == "Ribbon Pivot"
                    if tradeDir == 1
                        trailSL := math.max(trailSL, rPivot)
                    if tradeDir == -1
                        trailSL := math.min(trailSL, rPivot)
                    trailState := "RUNNER SL RIBBON"

                else
                    trailState := "RUNNER OPEN"

                trailEvent := true

                if showPlan and not na(trailSL)
                    if not na(slLine)
                        line.delete(slLine)
                    if not na(slLabel)
                        label.delete(slLabel)

                    lxTrail = bar_index + labelOffsetBars
                    tickSpaceTrail = syminfo.mintick * labelSpacingTicks

                    slLine := line.new(bar_index, trailSL, bar_index + lineBars, trailSL, extend=extend.right, color=color.orange, width=lineWidth + 2, style=line.style_dashed)

                    slLabel := label.new(lxTrail, trailSL - tickSpaceTrail, trailState + "\n" + str.tostring(trailSL, format.mintick), style=label.style_label_left, color=color.orange, textcolor=color.black, size=plannerLabelSize)

            if t3Behavior == "Complete Trade"
                tradeStatus := "Completed T3"
                activeTrade := false
                runnerActive := false

                if resetCooldownOnCompletion
                    lastSetupBar := na

                if hideTargetsOnComplete
                    f_clearPlanLinesKeepStatus()

                if not na(statusLabel)
                    label.set_text(statusLabel, currentSetup + "\nCOMPLETED T3")
                    label.set_color(statusLabel, color.blue)
                    label.set_textcolor(statusLabel, color.white)

                if deleteOnComplete
                    f_deletePlan()
            else
                tradeStatus := "Runner After T3"
                runnerEvent := true
                activeTrade := true
                runnerActive := true
                runnerTargetNumber := 4
                lastRunnerHitPrice := t3Price

                runnerTargetPrice := f_runnerNextTarget(tradeDir, t3Price)

                if na(runnerTargetPrice) and runnerTargetMode == "Points"
                    runnerTargetPrice := tradeDir == 1 ? t3Price + manualT1Pts : t3Price - manualT1Pts

                if showRunnerTarget and not na(runnerTargetPrice) and showPlan
                    if not na(runnerTargetLine)
                        line.delete(runnerTargetLine)
                    if not na(runnerTargetLabel)
                        label.delete(runnerTargetLabel)

                    runnerTargetLine := line.new(bar_index, runnerTargetPrice, bar_index + lineBars, runnerTargetPrice, extend=extend.right, color=color.purple, width=lineWidth)

                    runnerTargetLabel := label.new(bar_index + labelOffsetBars, runnerTargetPrice, "NEXT\n" + str.tostring(runnerTargetPrice, format.mintick), style=label.style_label_left, color=color.purple, textcolor=color.white, size=plannerLabelSize)

                if na(runnerTargetPrice)
                    tradeStatus := "Runner After T3 - No Next Saty"

                if not na(statusLabel)
                    label.set_text(statusLabel, currentSetup + "\n" + tradeStatus)
                    label.set_color(statusLabel, color.purple)
                    label.set_textcolor(statusLabel, color.white)

        // -------------------------------
        // RUNNER NEXT HIT
        // -------------------------------
        runnerTargetHit =
             runnerActive and
             activeTrade and
             not na(runnerTargetPrice) and
             (
                 tradeDir == 1 ? high >= runnerTargetPrice :
                 tradeDir == -1 ? low <= runnerTargetPrice :
                 false
             )

        if runnerTargetHit
            runnerNextHitEvent := true
            lastRunnerHitPrice := runnerTargetPrice
            runnerTargetNumber += 1

            // Move SL to the runner target that was just hit.
            if trailMode == "Prior Target"
                if tradeDir == 1
                    trailSL := math.max(trailSL, runnerTargetPrice)
                if tradeDir == -1
                    trailSL := math.min(trailSL, runnerTargetPrice)

                trailState := "SL NEXT"
                trailEvent := true

                if showPlan and not na(trailSL)
                    if not na(slLine)
                        line.delete(slLine)
                    if not na(slLabel)
                        label.delete(slLabel)

                    lxTrail = bar_index + labelOffsetBars
                    tickSpaceTrail = syminfo.mintick * labelSpacingTicks

                    slLine := line.new(bar_index, trailSL, bar_index + lineBars, trailSL, extend=extend.right, color=color.orange, width=lineWidth + 2, style=line.style_dashed)

                    slLabel := label.new(lxTrail, trailSL - tickSpaceTrail, trailState + "\n" + str.tostring(trailSL, format.mintick), style=label.style_label_left, color=color.orange, textcolor=color.black, size=plannerLabelSize)

            // Find next Saty runner target after the level just hit.
            nextRunnerLevel = f_runnerNextTarget(tradeDir, lastRunnerHitPrice)

            if na(nextRunnerLevel) and runnerTargetMode == "Points"
                nextRunnerLevel := tradeDir == 1 ? lastRunnerHitPrice + manualT1Pts : lastRunnerHitPrice - manualT1Pts

            if not na(nextRunnerLevel)
                runnerTargetPrice := nextRunnerLevel
                tradeStatus := "Runner NEXT " + str.tostring(runnerTargetNumber - 1) + " Hit"

                if showRunnerTarget and showPlan
                    if not na(runnerTargetLine)
                        line.delete(runnerTargetLine)
                    if not na(runnerTargetLabel)
                        label.delete(runnerTargetLabel)

                    runnerTargetLine := line.new(bar_index, runnerTargetPrice, bar_index + lineBars, runnerTargetPrice, extend=extend.right, color=color.purple, width=lineWidth)

                    runnerTargetLabel := label.new(bar_index + labelOffsetBars, runnerTargetPrice, "NEXT\n" + str.tostring(runnerTargetPrice, format.mintick), style=label.style_label_left, color=color.purple, textcolor=color.white, size=plannerLabelSize)

                if not na(statusLabel)
                    label.set_text(statusLabel, currentSetup + "\n" + tradeStatus)
                    label.set_color(statusLabel, color.purple)
                    label.set_textcolor(statusLabel, color.white)
            else
                runnerActive := false
                runnerMaxEvent := true
                tradeStatus := "Runner Max Target"

                if not na(runnerTargetLine)
                    line.delete(runnerTargetLine)
                if not na(runnerTargetLabel)
                    label.delete(runnerTargetLabel)

                runnerTargetPrice := na

                if not na(statusLabel)
                    label.set_text(statusLabel, currentSetup + "\nRUNNER MAX TARGET")
                    label.set_color(statusLabel, color.purple)
                    label.set_textcolor(statusLabel, color.white)

        // -------------------------------
        // STOP HIT AFTER TARGET CHECK
        // Only used when conservativeStops = false.
        // -------------------------------
        if stopHit and not conservativeStops
            tradeStatus := t3WasHit ? "Runner Stopped After T3" : t2WasHit ? "Stopped After T2" : t1WasHit ? "Stopped BE/After T1" : "Stopped Before T1"
            stopEvent := true
            activeTrade := false

            if resetCooldownOnStop
                lastSetupBar := na

            if hideTargetsOnStop
                f_clearPlanLinesKeepStatus()

            if not na(statusLabel)
                label.set_text(statusLabel, currentSetup + "\n" + tradeStatus)
                label.set_color(statusLabel, color.orange)
                label.set_textcolor(statusLabel, color.black)

            if deleteOnComplete
                f_deletePlan()

// =====================================================================
// 13. VISUALS
// =====================================================================

plot(showPlannerEMAs ? rFast : na, "Planner EMA 8", color=color.new(color.lime, 0))
plot(showPlannerEMAs ? rPull : na, "Planner EMA 13 Pullback", color=color.new(color.aqua, 0))
plot(showPlannerEMAs ? rPivot : na, "Planner EMA 21 Pivot", color=color.new(color.yellow, 0))
plot(showPlannerEMAs ? rSlow : na, "Planner EMA 34 Signal Slow", color=color.new(color.red, 0))
plot(showPlannerEMAs ? rLong : na, "Planner EMA 200", color=color.new(color.blue, 0))

plot(showPlannerSatyLevels ? satyUpperTrigger : na, "Planner Saty Upper Trigger", color=color.new(color.aqua, 35), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLowerTrigger : na, "Planner Saty Lower Trigger", color=color.new(color.yellow, 35), style=plot.style_stepline)

plot(showPlannerSatyLevels ? satyUpper382 : na, "Planner Saty +38.2 GG Open", color=color.new(color.green, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper500 : na, "Planner Saty +50", color=color.new(color.silver, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper618 : na, "Planner Saty +61.8 GG Complete", color=color.new(color.white, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper786 : na, "Planner Saty +78.6", color=color.new(color.purple, 50), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper100 : na, "Planner Saty +100", color=color.new(color.white, 55), style=plot.style_stepline)

plot(showPlannerSatyLevels ? satyUpper1236 : na, "Planner Saty +123.6", color=color.new(color.blue, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper1382 : na, "Planner Saty +138.2", color=color.new(color.blue, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper1500 : na, "Planner Saty +150", color=color.new(color.blue, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper1618 : na, "Planner Saty +161.8", color=color.new(color.blue, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper1786 : na, "Planner Saty +178.6", color=color.new(color.blue, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyUpper2000 : na, "Planner Saty +200", color=color.new(color.blue, 55), style=plot.style_stepline)

plot(showPlannerSatyLevels ? satyLower382 : na, "Planner Saty -38.2 GG Open", color=color.new(color.red, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower500 : na, "Planner Saty -50", color=color.new(color.silver, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower618 : na, "Planner Saty -61.8 GG Complete", color=color.new(color.white, 45), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower786 : na, "Planner Saty -78.6", color=color.new(color.purple, 50), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower100 : na, "Planner Saty -100", color=color.new(color.white, 55), style=plot.style_stepline)

plot(showPlannerSatyLevels ? satyLower1236 : na, "Planner Saty -123.6", color=color.new(color.purple, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower1382 : na, "Planner Saty -138.2", color=color.new(color.purple, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower1500 : na, "Planner Saty -150", color=color.new(color.purple, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower1618 : na, "Planner Saty -161.8", color=color.new(color.purple, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower1786 : na, "Planner Saty -178.6", color=color.new(color.purple, 55), style=plot.style_stepline)
plot(showPlannerSatyLevels ? satyLower2000 : na, "Planner Saty -200", color=color.new(color.purple, 55), style=plot.style_stepline)


// Raw setup markers.
plotshape(showRawMarkers and ggBull, title="Raw GG Bull", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny, text="GG")
plotshape(showRawMarkers and ggBear, title="Raw GG Bear", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, text="GG")
plotshape(showRawMarkers and flagBull, title="Raw Flag Bull", style=shape.diamond, location=location.belowbar, color=color.aqua, size=size.tiny, text="F")
plotshape(showRawMarkers and flagBear, title="Raw Flag Bear", style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.tiny, text="F")
plotshape(showRawMarkers and iVomyBull, title="Raw iVOMY Bull", style=shape.circle, location=location.belowbar, color=color.aqua, textcolor=color.black, size=size.tiny, text="iV")
plotshape(showRawMarkers and vomyBear, title="Raw VOMY Bear", style=shape.circle, location=location.abovebar, color=color.orange, textcolor=color.white, size=size.tiny, text="V")
plotshape(showRawMarkers and btBull, title="Raw BT Bull", style=shape.square, location=location.belowbar, color=color.green, size=size.tiny, text="BT")
plotshape(showRawMarkers and btBear, title="Raw BT Bear", style=shape.square, location=location.abovebar, color=color.red, size=size.tiny, text="BT")

// Transition debug markers.
plotshape(showTransitionDebug and iVomyArm, title="iVOMY Armed", style=shape.circle, location=location.belowbar, color=color.aqua, textcolor=color.black, size=size.tiny, text="iV arm")
plotshape(showTransitionDebug and vomyArm, title="VOMY Armed", style=shape.circle, location=location.abovebar, color=color.orange, textcolor=color.white, size=size.tiny, text="V arm")

plotshape(showTransitionDebug and bullTransitionActive, title="iVOMY Active Window", style=shape.square, location=location.belowbar, color=color.new(color.aqua, 70), size=size.tiny, text="")
plotshape(showTransitionDebug and bearTransitionActive, title="VOMY Active Window", style=shape.square, location=location.abovebar, color=color.new(color.orange, 70), size=size.tiny, text="")

// Actionable setup markers.
plotshape(showActionableMarkers and newBullSetup and currentSetupKey == "GG", title="Action GG Bull", style=shape.labelup, location=location.belowbar, color=color.green, size=size.tiny, text="GG")
plotshape(showActionableMarkers and newBearSetup and currentSetupKey == "GG", title="Action GG Bear", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.tiny, text="GG")

plotshape(showActionableMarkers and newBullSetup and currentSetupKey == "FLAG_INTO_RIBBON", title="Action Flag Bull", style=shape.labelup, location=location.belowbar, color=color.aqua, size=size.tiny, text="FLAG")
plotshape(showActionableMarkers and newBearSetup and currentSetupKey == "FLAG_INTO_RIBBON", title="Action Flag Bear", style=shape.labeldown, location=location.abovebar, color=color.yellow, size=size.tiny, text="FLAG")

plotshape(showActionableMarkers and newBullSetup and currentSetupKey == "IVOMY", title="Action iVOMY Bull", style=shape.labelup, location=location.belowbar, color=color.aqua, textcolor=color.black, size=size.tiny, text="iV")
plotshape(showActionableMarkers and newBearSetup and currentSetupKey == "VOMY", title="Action VOMY Bear", style=shape.labeldown, location=location.abovebar, color=color.orange, textcolor=color.white, size=size.tiny, text="V")

plotshape(showActionableMarkers and newBullSetup and currentSetupKey == "BT", title="Action BT Bull", style=shape.labelup, location=location.belowbar, color=color.lime, size=size.tiny, text="BT")
plotshape(showActionableMarkers and newBearSetup and currentSetupKey == "BT", title="Action BT Bear", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.tiny, text="BT")

plotshape(showActionableMarkers and newBullSetup and currentSetupKey == "ORB_RETEST", title="Action ORB Retest Bull", style=shape.labelup, location=location.belowbar, color=color.green, size=size.tiny, text="ORB")
plotshape(showActionableMarkers and newBearSetup and currentSetupKey == "ORB_RETEST", title="Action ORB Retest Bear", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.tiny, text="ORB")

// =====================================================================
// 14. DASHBOARD
// =====================================================================

var table dash = table.new(dashPos, 2, 10, border_width=1)

if barstate.islast and showDashboard
    ribbonText = ribbonBull ? "BULL" : ribbonBear ? "BEAR" : "MIXED"

    table.cell(dash, 0, 0, "Ribbon", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
    table.cell(dash, 1, 0, ribbonText, text_color=color.white, bgcolor=ribbonBull ? color.green : ribbonBear ? color.red : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 1, "Setup", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
    table.cell(dash, 1, 1, currentSetup, text_color=color.white, bgcolor=color.black, text_size=size.tiny)

    table.cell(dash, 0, 2, "Entry", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
    table.cell(dash, 1, 2, na(entryPrice) ? "—" : str.tostring(entryPrice, format.mintick), text_color=color.white, bgcolor=color.black, text_size=size.tiny)

    table.cell(dash, 0, 3, "Status", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
    table.cell(dash, 1, 3, tradeStatus, text_color=color.white, bgcolor=tradeStatus == "Active" ? color.green : str.contains(tradeStatus, "Hit") ? color.blue : str.contains(tradeStatus, "Stopped") ? color.orange : str.contains(tradeStatus, "Completed") ? color.purple : str.contains(tradeStatus, "Runner") ? color.purple : tradeStatus == "Invalidated" ? color.gray : color.silver, text_size=size.tiny)

    table.cell(dash, 0, 4, "Trail SL", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
    table.cell(dash, 1, 4, na(trailSL) ? "—" : str.tostring(trailSL, format.mintick), text_color=color.white, bgcolor=color.black, text_size=size.tiny)

    if dashboardMode == "Full"
        table.cell(dash, 0, 5, "HTF", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
        table.cell(dash, 1, 5, htfText, text_color=color.white, bgcolor=htfText == "BULL" ? color.green : htfText == "BEAR" ? color.red : color.gray, text_size=size.tiny)

        table.cell(dash, 0, 6, "T1", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
        table.cell(dash, 1, 6, na(t1Price) ? "—" : str.tostring(t1Price, format.mintick), text_color=color.white, bgcolor=color.black, text_size=size.tiny)

        table.cell(dash, 0, 7, "T2", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
        table.cell(dash, 1, 7, na(t2Price) ? "—" : str.tostring(t2Price, format.mintick), text_color=color.white, bgcolor=color.black, text_size=size.tiny)

        table.cell(dash, 0, 8, "T3", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
        table.cell(dash, 1, 8, na(t3Price) ? "—" : str.tostring(t3Price, format.mintick), text_color=color.white, bgcolor=color.black, text_size=size.tiny)

        table.cell(dash, 0, 9, "Grade", text_color=color.white, bgcolor=color.black, text_size=size.tiny)
        table.cell(dash, 1, 9, currentGrade, text_color=color.white, bgcolor=currentGrade == "A+" ? color.green : color.gray, text_size=size.tiny)

// =====================================================================
// 15. ALERTS
// =====================================================================

// alertcondition(newBullEvent, title="Bullish setup detected", message="Bullish setup detected")
// alertcondition(newBearEvent, title="Bearish setup detected", message="Bearish setup detected")
// alertcondition(entryEvent, title="Entry triggered", message="Entry triggered")
// alertcondition(t1Event, title="Target 1 hit", message="Target 1 hit")
// alertcondition(t2Event, title="Target 2 hit", message="Target 2 hit")
// alertcondition(t3Event, title="Target 3 hit", message="Target 3 hit")
// alertcondition(runnerEvent, title="Runner after T3", message="Runner after T3")
// alertcondition(stopEvent, title="Stop loss hit", message="Stop loss hit")
// alertcondition(invalidEvent, title="Bias invalidated", message="Bias invalidated")
// alertcondition(trailEvent, title="Trailing SL updated", message="Trailing SL updated")
// alertcondition(runnerNextHitEvent, title="Runner NEXT hit", message="Runner NEXT hit")
// alertcondition(runnerMaxEvent, title="Runner max target", message="Runner max target")
// alertcondition(reversalExitEvent, title="Reversal exit", message="Reversal exit")

anyPlannerEvent =
     newBullEvent or
     newBearEvent or
     entryEvent or
     t1Event or
     t2Event or
     t3Event or
     runnerEvent or
     runnerNextHitEvent or
     runnerMaxEvent or
     stopEvent or
     invalidEvent or
     trailEvent or
     reversalExitEvent

alertcondition(anyPlannerEvent, title="OTD Manual Planner Any Event", message="OTD Manual Planner event")

if useDynamicAlerts and barstate.isconfirmed
    dirAlert = tradeDir == 1 ? "BULL" : tradeDir == -1 ? "BEAR" : "NONE"
    atrLevelName = not na(t1Price) ? f_atrLevelName(t1Price, tradeDir) : "none"

    if sendTestAlert and not testAlertSent
        testAlertSent := true
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"MANUAL PLANNER TEST","price":"' + str.tostring(close) + '","signal":"TEST","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if reversalExitEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"REVERSAL EXIT","price":"' + str.tostring(close) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"EXIT","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if newBullEvent or newBearEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"' + currentSetup + '","price":"' + str.tostring(entryPrice) + '","entry":"' + str.tostring(entryPrice) + '","t1":"' + str.tostring(t1Price) + '","t2":"' + str.tostring(t2Price) + '","t3":"' + str.tostring(t3Price) + '","sl":"' + str.tostring(slPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","atr_level":"' + atrLevelName + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"ENTRY","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if t1Event
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"T1 HIT","price":"' + str.tostring(t1Price) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","atr_level":"' + f_atrLevelName(t1Price, tradeDir) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TARGET","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if t2Event
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"T2 HIT","price":"' + str.tostring(t2Price) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","atr_level":"' + f_atrLevelName(t2Price, tradeDir) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TARGET","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if t3Event
        t3Signal = t3Behavior == "Complete Trade" ? "EXIT" : "TARGET"
        t3Condition = t3Behavior == "Complete Trade" ? "T3 HIT - COMPLETED" : "T3 HIT - RUNNER"
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"' + t3Condition + '","price":"' + str.tostring(t3Price) + '","entry":"' + str.tostring(entryPrice) + '","t1":"' + str.tostring(t1Price) + '","t2":"' + str.tostring(t2Price) + '","t3":"' + str.tostring(t3Price) + '","sl":"' + str.tostring(slPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","atr_level":"' + f_atrLevelName(t3Price, tradeDir) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"' + t3Signal + '","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if runnerEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"RUNNER AFTER T3","price":"' + str.tostring(close) + '","entry":"' + str.tostring(entryPrice) + '","t1":"' + str.tostring(t1Price) + '","t2":"' + str.tostring(t2Price) + '","t3":"' + str.tostring(t3Price) + '","sl":"' + str.tostring(slPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TRAIL","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if stopEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"STOP HIT","price":"' + str.tostring(trailSL) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"STOP","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if invalidEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"BIAS INVALIDATED","price":"' + str.tostring(close) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"EXIT","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)
    
    if runnerNextHitEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"RUNNER NEXT HIT","price":"' + str.tostring(lastRunnerHitPrice) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","next_target":"' + str.tostring(runnerTargetPrice) + '","atr_level":"' + f_atrLevelName(lastRunnerHitPrice, tradeDir) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TARGET","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if runnerMaxEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"RUNNER MAX TARGET","price":"' + str.tostring(lastRunnerHitPrice) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TARGET","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)

    if trailEvent
        alert('{"ticker":"' + syminfo.ticker + '","timeframe":"' + timeframe.period + '","condition":"TRAILING SL UPDATED","price":"' + str.tostring(close) + '","entry":"' + str.tostring(entryPrice) + '","trail_sl":"' + str.tostring(trailSL) + '","setup":"' + currentSetupKey + '","grade":"' + currentGrade + '","direction":"' + dirAlert + '","signal":"TRAIL","secret":"' + tvSecret + '"}', alert.freq_once_per_bar_close)